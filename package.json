{
  "name": "monday-integration-quickstart-app-typescript",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npx concurrently \"npx ts-node-dev --respawn --transpile-only src/app.ts\" \"cd client && npm run dev\"",
    "dev-server": "npm run stop && npx concurrently \"cd backend-node && npm run dev\" \"npm run expose\"",
    "build": "npx tsc && cd client && npm i && npm run build && cd ..",
    "start": "node dist/app.js",
    "expose": "mapps tunnel:create -p 8080",
    "stop": "npx kill-port 8080",
    "deploy": "npm run client-build && mapps code:push",
    "client-build": "cd client && npm run build",
    "fetch:schema": "bash fetch-schema.sh",
    "codegen": "graphql-codegen",
    "fetch:generate": "npm run fetch:schema && npm run codegen"
  },
  "dependencies": {
    "@mondaycom/apps-sdk": "^3.0.11",
    "@mondaydotcomorg/api": "^7.0.1",
    "@sparticuz/chromium": "^148.0.0",
    "axios": "^1.6.0",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "dotenv": "^5.0.1",
    "express": "^4.17.1",
    "form-data": "^4.0.0",
    "graphql": "^16.8.2",
    "graphql-request": "^6.1.0",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.2",
    "monday-sdk-js": "^0.5.2",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "puppeteer": "^24.43.1",
    "puppeteer-core": "^24.43.1",
    "querystring": "^0.2.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typescript": "^4.1.2",
    "@graphql-codegen/typescript-operations": "^4.4.0",
    "@types/express": "^4.17.9",
    "@types/jsonwebtoken": "^8.5.0",
    "concurrently": "^8.2.2",
    "cross-port-killer": "^1.2.1",
    "debug": "~2.6.9",
    "eslint": "^v6.8.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
